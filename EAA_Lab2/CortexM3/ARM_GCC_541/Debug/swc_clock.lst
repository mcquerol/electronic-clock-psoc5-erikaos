 337:.\Source\rte/sc_clock.h **** inline RC_t RTE_SC_CLOCK_pullPort( SC_CLOCK_t * const signal )
 338:.\Source\rte/sc_clock.h **** {                                                                                                  
 339:.\Source\rte/sc_clock.h ****    RC_t ret = RC_SUCCESS;
 340:.\Source\rte/sc_clock.h **** 
 341:.\Source\rte/sc_clock.h ****                                                                                                    
 342:.\Source\rte/sc_clock.h ****    if ( NULL != signal->pSigCfg->inDriver )
 343:.\Source\rte/sc_clock.h ****    {
 344:.\Source\rte/sc_clock.h **** 	  SC_CLOCK_data_t value = signal->value;
 345:.\Source\rte/sc_clock.h ****       ret = signal->pSigCfg->inDriver(&value);
 346:.\Source\rte/sc_clock.h ****                                                                                                    
 347:.\Source\rte/sc_clock.h ****       if ( ret == RC_SUCCESS )                                                                     
 348:.\Source\rte/sc_clock.h ****       {
 349:.\Source\rte/sc_clock.h ****     	  //Critical Section
 350:.\Source\rte/sc_clock.h ****     	  RTE_SC_CLOCK_set(signal, value);
 351:.\Source\rte/sc_clock.h ****       }
 352:.\Source\rte/sc_clock.h ****       else
 353:.\Source\rte/sc_clock.h ****       {
 354:.\Source\rte/sc_clock.h **** 		  //Signal is invalid. Error event (if present) will be fired
 355:.\Source\rte/sc_clock.h **** 		  RTE_SC_CLOCK_setStatus(signal, RTE_SIGNALSTATUS_INVALID);
 356:.\Source\rte/sc_clock.h ****       }
 357:.\Source\rte/sc_clock.h **** 
 358:.\Source\rte/sc_clock.h ****    }                                                                                               
 359:.\Source\rte/sc_clock.h ****                                                                                                    
 360:.\Source\rte/sc_clock.h ****    return ret;                                                                                     
 361:.\Source\rte/sc_clock.h **** }                                                                                                  
