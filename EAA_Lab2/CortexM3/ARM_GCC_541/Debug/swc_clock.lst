 195:.\Source\rte/sc_clock.h ****  * @param  SC_CLOCK_t * const signal: Pointer to the signal object
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccyrSPLo.s 			page 16


 196:.\Source\rte/sc_clock.h ****  * @param  const sig_status_t status: New signal status
 197:.\Source\rte/sc_clock.h ****  * @return RC_t: standard return code, currently only RC_SUCCESS
 198:.\Source\rte/sc_clock.h ****  *
 199:.\Source\rte/sc_clock.h ****  */
 200:.\Source\rte/sc_clock.h **** inline RC_t RTE_SC_CLOCK_setStatus( SC_CLOCK_t * const signal, const RTE_signalStatus_t status )
 201:.\Source\rte/sc_clock.h **** {
 202:.\Source\rte/sc_clock.h ****    signal->status = status;
 203:.\Source\rte/sc_clock.h ****    size_t taskNum=0;
 204:.\Source\rte/sc_clock.h ****    
 205:.\Source\rte/sc_clock.h ****    //Fire error events in case of invalid state
 206:.\Source\rte/sc_clock.h ****    if (signal->status == RTE_SIGNALSTATUS_INVALID)
 207:.\Source\rte/sc_clock.h ****    {
 208:.\Source\rte/sc_clock.h **** 	    //Pointer to the Taskarray, containing the tasks receiving the onUpdate events
 209:.\Source\rte/sc_clock.h **** 		TaskTypeArray* pTaskArray = signal->pSigCfg->onErrorTasks;
 210:.\Source\rte/sc_clock.h **** 
 211:.\Source\rte/sc_clock.h **** 		if (NULL!=signal->pSigCfg->evOnError && NULL != pTaskArray){
 212:.\Source\rte/sc_clock.h **** 			for( taskNum=0 ; taskNum < signal->pSigCfg->onErrorTaskCount ;taskNum++){
 213:.\Source\rte/sc_clock.h **** 				TaskType task = (*pTaskArray)[taskNum];
 214:.\Source\rte/sc_clock.h **** 				SetEvent( task, signal->pSigCfg->evOnError);
 215:.\Source\rte/sc_clock.h **** 			}
 216:.\Source\rte/sc_clock.h **** 		}
 217:.\Source\rte/sc_clock.h ****    }
 218:.\Source\rte/sc_clock.h ****    
 219:.\Source\rte/sc_clock.h ****    return RC_SUCCESS;
 220:.\Source\rte/sc_clock.h **** }
 221:.\Source\rte/sc_clock.h **** 
