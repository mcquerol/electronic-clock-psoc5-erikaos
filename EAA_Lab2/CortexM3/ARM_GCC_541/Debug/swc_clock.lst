 200:.\Source\rte/sc_event.h **** inline RC_t RTE_SC_EVENT_setStatus( SC_EVENT_t * const signal, const RTE_signalStatus_t status )
 201:.\Source\rte/sc_event.h **** {
 202:.\Source\rte/sc_event.h ****    signal->status = status;
 203:.\Source\rte/sc_event.h ****    size_t taskNum=0;
 204:.\Source\rte/sc_event.h ****    
 205:.\Source\rte/sc_event.h ****    //Fire error events in case of invalid state
 206:.\Source\rte/sc_event.h ****    if (signal->status == RTE_SIGNALSTATUS_INVALID)
 207:.\Source\rte/sc_event.h ****    {
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccyrSPLo.s 			page 7


 208:.\Source\rte/sc_event.h **** 	    //Pointer to the Taskarray, containing the tasks receiving the onUpdate events
 209:.\Source\rte/sc_event.h **** 		TaskTypeArray* pTaskArray = signal->pSigCfg->onErrorTasks;
 210:.\Source\rte/sc_event.h **** 
 211:.\Source\rte/sc_event.h **** 		if (NULL!=signal->pSigCfg->evOnError && NULL != pTaskArray){
 212:.\Source\rte/sc_event.h **** 			for( taskNum=0 ; taskNum < signal->pSigCfg->onErrorTaskCount ;taskNum++){
 213:.\Source\rte/sc_event.h **** 				TaskType task = (*pTaskArray)[taskNum];
 214:.\Source\rte/sc_event.h **** 				SetEvent( task, signal->pSigCfg->evOnError);
 215:.\Source\rte/sc_event.h **** 			}
 216:.\Source\rte/sc_event.h **** 		}
 217:.\Source\rte/sc_event.h ****    }
 218:.\Source\rte/sc_event.h ****    
 219:.\Source\rte/sc_event.h ****    return RC_SUCCESS;
 220:.\Source\rte/sc_event.h **** }
