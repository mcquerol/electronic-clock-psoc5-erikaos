 134:clock_type.c  **** //CLOCK_setEditFonts
 135:clock_type.c  **** //Chooses which of the editing widgets is active.
 136:clock_type.c  **** static void CLOCK_setEditFonts()
 137:clock_type.c  **** {
 138:clock_type.c  ****     UART_LOG_PutString("Set Edit Fonts \n");
 139:clock_type.c  ****     
 140:clock_type.c  ****     SC_CLOCK_data_t localClock = RTE_SC_CLOCK_get(&SO_CLOCK_signal);
 141:clock_type.c  ****     
 142:clock_type.c  ****     if(CLOCK_hour_widget == localClock.m_activeWidget) {
 143:clock_type.c  ****         
 144:clock_type.c  ****         localClock.m_hours.m_fontEditing = TRUE;
 145:clock_type.c  ****         
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccUsGJqR.s 			page 4


 146:clock_type.c  ****         localClock.m_minutes.m_fontEditing = FALSE;
 147:clock_type.c  ****     }
 148:clock_type.c  ****     else if (CLOCK_minute_widget == localClock.m_activeWidget){
 149:clock_type.c  ****         
 150:clock_type.c  ****         localClock.m_hours.m_fontEditing = FALSE;
 151:clock_type.c  ****         
 152:clock_type.c  ****         localClock.m_minutes.m_fontEditing = TRUE;
 153:clock_type.c  ****     }
 154:clock_type.c  ****     else
 155:clock_type.c  ****     {
 156:clock_type.c  ****         //Intended to do nothing.
 157:clock_type.c  ****     }
 158:clock_type.c  ****     
 159:clock_type.c  ****     RTE_SC_CLOCK_set(&SO_CLOCK_signal, localClock);
 160:clock_type.c  **** }
