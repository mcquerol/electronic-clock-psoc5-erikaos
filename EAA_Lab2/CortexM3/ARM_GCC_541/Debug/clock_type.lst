 152:.\Source\rte/sc_clock.h **** /**
 153:.\Source\rte/sc_clock.h ****  * Initializes a signal instance with a passed init value.
 154:.\Source\rte/sc_clock.h ****  * Depending on the configured conversion or scaling function the raw_value will be calculated.
 155:.\Source\rte/sc_clock.h ****  * Signal status will change from RTE_SIGNALSTATUS_STARTUP to RTE_SIGNALSTATUS_INITIALIZED.
 156:.\Source\rte/sc_clock.h ****  *
 157:.\Source\rte/sc_clock.h ****  * @param  SC_CLOCK_t * const signal: Pointer to the signal object which will be initialised
 158:.\Source\rte/sc_clock.h ****  * @param const sc_clock_data_t * const value: Pointer to initial value of the application data
 159:.\Source\rte/sc_clock.h ****  * @return RC_t: standard return code, currently only RC_SUCCESS
 160:.\Source\rte/sc_clock.h ****  *
 161:.\Source\rte/sc_clock.h ****  **/
 162:.\Source\rte/sc_clock.h **** inline RC_t RTE_SC_CLOCK_init( SC_CLOCK_t * const signal, const SC_CLOCK_data_t * const value )
 163:.\Source\rte/sc_clock.h **** {                                                                                                  
 164:.\Source\rte/sc_clock.h **** 
 165:.\Source\rte/sc_clock.h ****    RC_t ret = RC_SUCCESS;
 166:.\Source\rte/sc_clock.h **** 
 167:.\Source\rte/sc_clock.h ****    //Set value and raw value
 168:.\Source\rte/sc_clock.h ****    signal->value  = *value;
 169:.\Source\rte/sc_clock.h ****    signal->age    = 0;
 170:.\Source\rte/sc_clock.h ****    signal->status = RTE_SIGNALSTATUS_INITIALIZED;
 171:.\Source\rte/sc_clock.h **** 
 172:.\Source\rte/sc_clock.h ****    return ret;
 173:.\Source\rte/sc_clock.h **** }
