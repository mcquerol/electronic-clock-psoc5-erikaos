 178:clock_type.c  **** //CLOCK_incrementWidget
 179:clock_type.c  **** //Increments the widget until it reaches its maximum value, then resets it to zero.
 180:clock_type.c  **** static void CLOCK_incrementWidget()
 181:clock_type.c  **** {
 182:clock_type.c  ****     UART_LOG_PutString("Increment Widget \n");
 183:clock_type.c  ****     
 184:clock_type.c  ****     SC_CLOCK_data_t localClock = RTE_SC_CLOCK_get(&SO_CLOCK_signal);
 185:clock_type.c  ****     
 186:clock_type.c  ****     if(CLOCK_minute_widget == localClock.m_activeWidget)
 187:clock_type.c  ****     {
 188:clock_type.c  ****         if(localClock.m_minutes.m_maxValue > localClock.m_minutes.m_currentValue)
 189:clock_type.c  ****         {
 190:clock_type.c  ****             localClock.m_minutes.m_currentValue++;   
 191:clock_type.c  ****         }
 192:clock_type.c  ****         else
 193:clock_type.c  ****         {
 194:clock_type.c  ****             localClock.m_minutes.m_currentValue = 0; 
 195:clock_type.c  ****         }
 196:clock_type.c  ****     }
 197:clock_type.c  ****     else if(CLOCK_hour_widget == localClock.m_activeWidget)
 198:clock_type.c  ****     {
 199:clock_type.c  ****         if(localClock.m_hours.m_maxValue > localClock.m_hours.m_currentValue)
 200:clock_type.c  ****         {
 201:clock_type.c  ****             localClock.m_hours.m_currentValue++;   
 202:clock_type.c  ****         }
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccUsGJqR.s 			page 5


 203:clock_type.c  ****         else
 204:clock_type.c  ****         {
 205:clock_type.c  ****             localClock.m_hours.m_currentValue = 0; 
 206:clock_type.c  ****         }
 207:clock_type.c  ****     }
 208:clock_type.c  ****     else
 209:clock_type.c  ****     {
 210:clock_type.c  ****         //Intended to do nothing.
 211:clock_type.c  ****     }
 212:clock_type.c  ****     
 213:clock_type.c  ****     RTE_SC_CLOCK_set(&SO_CLOCK_signal, localClock);
 214:clock_type.c  **** }
