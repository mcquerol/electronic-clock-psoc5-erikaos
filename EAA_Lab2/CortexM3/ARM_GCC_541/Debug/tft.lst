  39:Source\bsw\tft/tft.c **** #define MODULE_DC(x)        PPCAT(CFG_TFT_DC_PIN, x)      
  40:Source\bsw\tft/tft.c **** #define MODULE_RES(x)       PPCAT(CFG_TFT_RES_PIN, x)  
  41:Source\bsw\tft/tft.c **** #define TFT_DC_LOW          MODULE_DC(Write)(0)     /**< \brief Macro to set the DC(A0) pin LOW*/
  42:Source\bsw\tft/tft.c **** #define TFT_DC_HIGH         MODULE_DC(Write)(1)     /**< \brief Macro to set the DC(A0) pin HIGH*/
  43:Source\bsw\tft/tft.c **** #define TFT_RES_LOW         MODULE_RES(Write)(0)    /**< \brief Macro to set the Reset pin LOW*/
  44:Source\bsw\tft/tft.c **** #define TFT_RES_HIGH        MODULE_RES(Write)(1)    /**< \brief Macro to set the Reset pin HIGH*/
