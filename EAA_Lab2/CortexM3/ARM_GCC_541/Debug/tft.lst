  80:Source\bsw\tft/tft.c **** typedef enum{
  81:Source\bsw\tft/tft.c ****     TFT_CMD,                        /**< Payload is command. */
  82:Source\bsw\tft/tft.c ****     TFT_DATA,                       /**< Payload is data */
  83:Source\bsw\tft/tft.c ****     TFT_STREAM                      /**< D/C has already been set */
  84:Source\bsw\tft/tft.c **** }TFT_payload_t;
