  46:Source\bsw\tft/tft.c **** /** 
  47:Source\bsw\tft/tft.c **** * \brief swap 2 int 16 values
  48:Source\bsw\tft/tft.c **** */
  49:Source\bsw\tft/tft.c **** #ifndef _swap_int16_t
  50:Source\bsw\tft/tft.c **** #define _swap_int16_t(a, b) { int16_t t = a; a = b; b = t; }
  51:Source\bsw\tft/tft.c **** #endif
  52:Source\bsw\tft/tft.c **** 
  53:Source\bsw\tft/tft.c **** // The code comes from an AVR. Those are macros to overcome that strange PROGMEM read stuff
  54:Source\bsw\tft/tft.c **** #ifndef pgm_read_byte
  55:Source\bsw\tft/tft.c ****  #define pgm_read_byte(addr) (*(const unsigned char *)(addr))
  56:Source\bsw\tft/tft.c **** #endif
  57:Source\bsw\tft/tft.c **** #ifndef pgm_read_word
  58:Source\bsw\tft/tft.c ****  #define pgm_read_word(addr) (*(const unsigned short *)(addr))
  59:Source\bsw\tft/tft.c **** #endif
  60:Source\bsw\tft/tft.c **** #ifndef pgm_read_dword
  61:Source\bsw\tft/tft.c ****  #define pgm_read_dword(addr) (*(const unsigned long *)(addr))
  62:Source\bsw\tft/tft.c **** #endif
  63:Source\bsw\tft/tft.c **** 
  64:Source\bsw\tft/tft.c **** // Pointers are a peculiar case...typically 16-bit on AVR boards,
  65:Source\bsw\tft/tft.c **** // 32 bits elsewhere.  Try to accommodate both...
  66:Source\bsw\tft/tft.c **** #if !defined(__INT_MAX__) || (__INT_MAX__ > 0xFFFF)
  67:Source\bsw\tft/tft.c ****  #define pgm_read_pointer(addr) ((void *)pgm_read_dword(addr))
  68:Source\bsw\tft/tft.c **** #else
  69:Source\bsw\tft/tft.c ****  #define pgm_read_pointer(addr) ((void *)pgm_read_word(addr))
  70:Source\bsw\tft/tft.c **** #endif
  71:Source\bsw\tft/tft.c **** 
  72:Source\bsw\tft/tft.c **** #define TFT_write_cmd(x)            TFT_send(TFT_CMD,x)
  73:Source\bsw\tft/tft.c **** #define TFT_write_data(x)           TFT_send(TFT_DATA,x)
  74:Source\bsw\tft/tft.c **** #define TFT_write_stream(x)         TFT_send(TFT_STREAM,x)
