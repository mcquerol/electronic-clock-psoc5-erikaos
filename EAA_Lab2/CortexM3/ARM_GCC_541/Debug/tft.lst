 580:Source\bsw\tft/tft.c **** 
 581:Source\bsw\tft/tft.c **** // Bresenham's algorithm - thx wikpedia
 582:Source\bsw\tft/tft.c **** void TFT_writeLine(int16_t x0, int16_t y0, int16_t x1, int16_t y1,  TFT_color_t color) {
 583:Source\bsw\tft/tft.c ****     int16_t steep = _abs(y1 - y0) > _abs(x1 - x0);
 584:Source\bsw\tft/tft.c ****     if (steep) {
 585:Source\bsw\tft/tft.c ****         _swap_int16_t(x0, y0);
 586:Source\bsw\tft/tft.c ****         _swap_int16_t(x1, y1);
 587:Source\bsw\tft/tft.c ****     }
 588:Source\bsw\tft/tft.c **** 
 589:Source\bsw\tft/tft.c ****     if (x0 > x1) {
 590:Source\bsw\tft/tft.c ****         _swap_int16_t(x0, x1);
 591:Source\bsw\tft/tft.c ****         _swap_int16_t(y0, y1);
 592:Source\bsw\tft/tft.c ****     }
 593:Source\bsw\tft/tft.c **** 
 594:Source\bsw\tft/tft.c ****     int16_t dx, dy;
 595:Source\bsw\tft/tft.c ****     dx = x1 - x0;
 596:Source\bsw\tft/tft.c ****     dy = _abs(y1 - y0);
 597:Source\bsw\tft/tft.c **** 
