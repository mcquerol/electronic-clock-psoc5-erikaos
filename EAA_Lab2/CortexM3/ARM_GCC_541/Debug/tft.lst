 464:Source\bsw\tft/tft.c **** 
 465:Source\bsw\tft/tft.c **** void TFT_write(uint8_t c) {
 466:Source\bsw\tft/tft.c **** 
 467:Source\bsw\tft/tft.c ****     if(!gfxFont) {                              // 'Classic' built-in font
 468:Source\bsw\tft/tft.c **** 
 469:Source\bsw\tft/tft.c ****         if(c == '\n') {                         // Newline?
 470:Source\bsw\tft/tft.c ****             cursor_x  = 0;                      // Reset x to zero,
 471:Source\bsw\tft/tft.c ****             cursor_y += textsize * 8;           // advance y one line
 472:Source\bsw\tft/tft.c ****         } else if(c != '\r') {                  // Ignore carriage returns
 473:Source\bsw\tft/tft.c ****             if(wrap && ((cursor_x + textsize * 6) > _width)) { // Off right?
 474:Source\bsw\tft/tft.c ****                 cursor_x  = 0;                  // Reset x to zero,
 475:Source\bsw\tft/tft.c ****                 cursor_y += textsize * 8;       // advance y one line
 476:Source\bsw\tft/tft.c ****             }
 477:Source\bsw\tft/tft.c ****             TFT_drawChar(cursor_x, cursor_y, c, color, bgcolor, textsize);
 478:Source\bsw\tft/tft.c ****             cursor_x += textsize * 6;          // Advance x one char
 479:Source\bsw\tft/tft.c ****         }
 480:Source\bsw\tft/tft.c **** 
 481:Source\bsw\tft/tft.c ****     } else { // Custom font
 482:Source\bsw\tft/tft.c **** 
 483:Source\bsw\tft/tft.c ****         if(c == '\n') {
 484:Source\bsw\tft/tft.c ****             cursor_x  = 0;
 485:Source\bsw\tft/tft.c ****             cursor_y += (int16_t)textsize *
 486:Source\bsw\tft/tft.c ****                         (uint8_t)pgm_read_byte(&gfxFont->yAdvance);
 487:Source\bsw\tft/tft.c ****         } else if(c != '\r') {
 488:Source\bsw\tft/tft.c ****             uint8_t first = pgm_read_byte(&gfxFont->first);
 489:Source\bsw\tft/tft.c ****             if((c >= first) && (c <= (uint8_t)pgm_read_byte(&gfxFont->last))) {
 490:Source\bsw\tft/tft.c ****                 GFXglyph *glyph = &(((GFXglyph *)pgm_read_pointer(
 491:Source\bsw\tft/tft.c ****                   &gfxFont->glyph))[c - first]);
 492:Source\bsw\tft/tft.c ****                 uint8_t   w     = pgm_read_byte(&glyph->width),
 493:Source\bsw\tft/tft.c ****                           h     = pgm_read_byte(&glyph->height);
 494:Source\bsw\tft/tft.c ****                 if((w > 0) && (h > 0)) { // Is there an associated bitmap?
 495:Source\bsw\tft/tft.c ****                     int16_t xo = (int8_t)pgm_read_byte(&glyph->xOffset); // sic
 496:Source\bsw\tft/tft.c ****                     if(wrap && ((cursor_x + textsize * (xo + w)) > _width)) {
 497:Source\bsw\tft/tft.c ****                         cursor_x  = 0;
 498:Source\bsw\tft/tft.c ****                         cursor_y += (int16_t)textsize *
 499:Source\bsw\tft/tft.c ****                           (uint8_t)pgm_read_byte(&gfxFont->yAdvance);
 500:Source\bsw\tft/tft.c ****                     }
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccarMydG.s 			page 32


 501:Source\bsw\tft/tft.c ****                     TFT_drawChar(cursor_x, cursor_y, c, color, bgcolor, textsize);
 502:Source\bsw\tft/tft.c ****                 }
 503:Source\bsw\tft/tft.c ****                 cursor_x += (uint8_t)pgm_read_byte(&glyph->xAdvance) * (int16_t)textsize;
 504:Source\bsw\tft/tft.c ****             }
 505:Source\bsw\tft/tft.c ****         }
 506:Source\bsw\tft/tft.c **** 
 507:Source\bsw\tft/tft.c ****     }
 508:Source\bsw\tft/tft.c **** }
