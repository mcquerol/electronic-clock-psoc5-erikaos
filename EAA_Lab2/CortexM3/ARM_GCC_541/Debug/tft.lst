 193:Source\bsw\tft/tft.c **** void TFT_init(){
 194:Source\bsw\tft/tft.c ****     
 195:Source\bsw\tft/tft.c ****     //init local vars
 196:Source\bsw\tft/tft.c ****     _width    = CFG_TFT_WIDTH;
 197:Source\bsw\tft/tft.c ****     _height   = CFG_TFT_HEIGHT;
 198:Source\bsw\tft/tft.c ****     rotation=0;
 199:Source\bsw\tft/tft.c ****     cursor_x=0;
 200:Source\bsw\tft/tft.c ****     cursor_y=0;
 201:Source\bsw\tft/tft.c ****     textsize=1;
 202:Source\bsw\tft/tft.c ****     color=CFG_TFT_COLOR_TEXT;
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccarMydG.s 			page 5


 203:Source\bsw\tft/tft.c ****     bgcolor=CFG_TFT_COLOR_TEXTBG;
 204:Source\bsw\tft/tft.c ****     wrap=TRUE;
 205:Source\bsw\tft/tft.c ****     gfxFont=NULL;
 206:Source\bsw\tft/tft.c ****     ystart = xstart = colstart  = rowstart = 0;
 207:Source\bsw\tft/tft.c ****     
 208:Source\bsw\tft/tft.c ****     //init ringbuffer
 209:Source\bsw\tft/tft.c ****     TFT_RB_out.read=0;
 210:Source\bsw\tft/tft.c ****     TFT_RB_out.write=0;
 211:Source\bsw\tft/tft.c ****     TFT_RB_out.fill=0;
 212:Source\bsw\tft/tft.c ****     
 213:Source\bsw\tft/tft.c ****     //Start SPI Interface
 214:Source\bsw\tft/tft.c ****     MODULE_SPI(Start)();
 215:Source\bsw\tft/tft.c ****     
 216:Source\bsw\tft/tft.c ****     //Perform Hardware reset
 217:Source\bsw\tft/tft.c ****     TFT_RES_HIGH;
 218:Source\bsw\tft/tft.c ****     CFG_TFT_DELAY_MS(100);
 219:Source\bsw\tft/tft.c ****     TFT_RES_LOW;
 220:Source\bsw\tft/tft.c **** 	CFG_TFT_DELAY_MS(100);
 221:Source\bsw\tft/tft.c **** 	TFT_RES_HIGH;
 222:Source\bsw\tft/tft.c **** 	CFG_TFT_DELAY_MS(20);
 223:Source\bsw\tft/tft.c ****     
 224:Source\bsw\tft/tft.c ****     //Software reset
 225:Source\bsw\tft/tft.c ****     TFT_write_cmd(ST7735_SWRESET);
 226:Source\bsw\tft/tft.c ****     CFG_TFT_DELAY_MS(50);
 227:Source\bsw\tft/tft.c ****     
 228:Source\bsw\tft/tft.c ****     //sleep out
 229:Source\bsw\tft/tft.c ****     TFT_write_cmd(ST7735_SLPOUT);    //Sleep out
 230:Source\bsw\tft/tft.c **** 	CFG_TFT_DELAY_MS(120);              //Delay 120ms
 231:Source\bsw\tft/tft.c ****     
 232:Source\bsw\tft/tft.c ****     //send init commands
 233:Source\bsw\tft/tft.c ****     uint8_t* addr=(uint8_t*)SST35S_init_seq;    
 234:Source\bsw\tft/tft.c ****     uint8_t  numCommands, numArgs;
 235:Source\bsw\tft/tft.c ****     numCommands = *(addr++);        // Number of commands to follow
 236:Source\bsw\tft/tft.c ****     while(numCommands--) {          // For each command...
 237:Source\bsw\tft/tft.c ****         TFT_write_cmd(*(addr++));    // Read, issue command
 238:Source\bsw\tft/tft.c ****         numArgs  = *(addr++);       // Number of args to follow
 239:Source\bsw\tft/tft.c ****         while(numArgs--) {          // For each argument...
 240:Source\bsw\tft/tft.c ****           TFT_write_data(*(addr++));     // Read, issue argument
 241:Source\bsw\tft/tft.c ****         }
 242:Source\bsw\tft/tft.c ****     }
 243:Source\bsw\tft/tft.c ****     
 244:Source\bsw\tft/tft.c ****     //set roation
 245:Source\bsw\tft/tft.c ****     TFT_setRotation(CFG_TFT_ORIENTATION);
 246:Source\bsw\tft/tft.c ****     
 247:Source\bsw\tft/tft.c ****     //init RAM
 248:Source\bsw\tft/tft.c ****     TFT_fillScreen(BLACK);
 249:Source\bsw\tft/tft.c ****     
 250:Source\bsw\tft/tft.c ****     //activate backlight
 251:Source\bsw\tft/tft.c ****     MODULE_PWM(Start)();
 252:Source\bsw\tft/tft.c ****     MODULE_PWM(WriteCompare)(CFG_TFT_BACKLIGHT);
 253:Source\bsw\tft/tft.c **** }
