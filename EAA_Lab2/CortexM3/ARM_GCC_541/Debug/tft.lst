 137:Source\bsw\tft/tft.c **** //----------------- Ringbuffer
 138:Source\bsw\tft/tft.c **** 
 139:Source\bsw\tft/tft.c **** void __TFT_SPI_TX_ISR(void){
 140:Source\bsw\tft/tft.c ****     
 141:Source\bsw\tft/tft.c ****     //check if we have data waiting
 142:Source\bsw\tft/tft.c ****     if(TFT_RB_out.fill==0)
 143:Source\bsw\tft/tft.c ****         return;
 144:Source\bsw\tft/tft.c ****     
 145:Source\bsw\tft/tft.c ****     //get the next frame to be send
ARM GAS  C:\Users\mau_g\AppData\Local\Temp\ccarMydG.s 			page 4


 146:Source\bsw\tft/tft.c ****     TFT_data_t* p_next_frame=&TFT_RB_out.buffer[TFT_RB_out.read++];
 147:Source\bsw\tft/tft.c ****     
 148:Source\bsw\tft/tft.c ****     //adjust read index and fill level
 149:Source\bsw\tft/tft.c ****     TFT_RB_out.read%=CFG_TFT_RB_OUT_SZ;
 150:Source\bsw\tft/tft.c ****     TFT_RB_out.fill--;
 151:Source\bsw\tft/tft.c ****     
 152:Source\bsw\tft/tft.c ****     //check payload type
 153:Source\bsw\tft/tft.c ****     switch(p_next_frame->DC){
 154:Source\bsw\tft/tft.c ****         case TFT_CMD:
 155:Source\bsw\tft/tft.c ****             TFT_DC_LOW;
 156:Source\bsw\tft/tft.c ****             break;
 157:Source\bsw\tft/tft.c ****         
 158:Source\bsw\tft/tft.c ****         case TFT_DATA:
 159:Source\bsw\tft/tft.c ****             TFT_DC_HIGH;
 160:Source\bsw\tft/tft.c ****             break;
 161:Source\bsw\tft/tft.c ****         default:
 162:Source\bsw\tft/tft.c ****         break;
 163:Source\bsw\tft/tft.c ****     }
 164:Source\bsw\tft/tft.c **** 
 165:Source\bsw\tft/tft.c ****     MODULE_SPI(WriteTxData)(p_next_frame->payload);    
 166:Source\bsw\tft/tft.c **** }
 167:Source\bsw\tft/tft.c **** 
 168:Source\bsw\tft/tft.c **** RC_t TFT_send(TFT_payload_t type, uint8_t payload){
 169:Source\bsw\tft/tft.c **** 
 170:Source\bsw\tft/tft.c ****     //check if buffer is full
 171:Source\bsw\tft/tft.c ****     if(TFT_RB_out.fill>=CFG_TFT_RB_OUT_SZ){
 172:Source\bsw\tft/tft.c ****         //TODO: fire event or DET STOP
 173:Source\bsw\tft/tft.c ****         LOG_E(TAG,"Buffer overflow");
 174:Source\bsw\tft/tft.c ****         return RC_ERROR_BUFFER_FULL;
 175:Source\bsw\tft/tft.c ****     }
 176:Source\bsw\tft/tft.c ****     
 177:Source\bsw\tft/tft.c ****     //add frame to buffer
 178:Source\bsw\tft/tft.c ****     TFT_RB_out.buffer[TFT_RB_out.write++]=(TFT_data_t){type,payload};
 179:Source\bsw\tft/tft.c **** 
 180:Source\bsw\tft/tft.c ****     //adjust write index and fill level
 181:Source\bsw\tft/tft.c ****     TFT_RB_out.write%=CFG_TFT_RB_OUT_SZ;
 182:Source\bsw\tft/tft.c ****     TFT_RB_out.fill++;
 183:Source\bsw\tft/tft.c ****     
 184:Source\bsw\tft/tft.c ****     //check if this is the only entry in the ringbuffer and trigger the ISR
 185:Source\bsw\tft/tft.c ****     if(TFT_RB_out.fill==1)
 186:Source\bsw\tft/tft.c ****         __TFT_SPI_TX_ISR();
 187:Source\bsw\tft/tft.c **** 
 188:Source\bsw\tft/tft.c ****     return RC_SUCCESS;
 189:Source\bsw\tft/tft.c **** }
