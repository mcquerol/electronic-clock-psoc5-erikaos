 548:Source\bsw\tft/tft.c **** void TFT_fastVLine(int16_t x, int16_t y, int16_t h, TFT_color_t color) {
 549:Source\bsw\tft/tft.c **** 
 550:Source\bsw\tft/tft.c ****   // Rudimentary clipping
 551:Source\bsw\tft/tft.c ****   if((x >= _width) || (y >= _height)) return;
 552:Source\bsw\tft/tft.c ****   if((y+h-1) >= _height) h = _height-y;
 553:Source\bsw\tft/tft.c ****   setAddrWindow(x, y, x, y+h-1);
 554:Source\bsw\tft/tft.c **** 
 555:Source\bsw\tft/tft.c ****   uint8_t hi = color >> 8, lo = color;
 556:Source\bsw\tft/tft.c ****     
 557:Source\bsw\tft/tft.c ****   TFT_DC_HIGH;
 558:Source\bsw\tft/tft.c ****   while (h--) {
 559:Source\bsw\tft/tft.c ****     TFT_write_stream(hi);
 560:Source\bsw\tft/tft.c ****     TFT_write_stream(lo);
 561:Source\bsw\tft/tft.c ****   }
 562:Source\bsw\tft/tft.c **** }
 563:Source\bsw\tft/tft.c **** 
 564:Source\bsw\tft/tft.c **** void TFT_fastHLine(int16_t x, int16_t y, int16_t w,  TFT_color_t color) {
 565:Source\bsw\tft/tft.c **** 
 566:Source\bsw\tft/tft.c ****     // Rudimentary clipping
 567:Source\bsw\tft/tft.c ****     if((x >= _width) || (y >= _height)) return;
 568:Source\bsw\tft/tft.c ****     if((x+w-1) >= _width)  w = _width-x;
 569:Source\bsw\tft/tft.c ****     setAddrWindow(x, y, x+w-1, y);
 570:Source\bsw\tft/tft.c **** 
 571:Source\bsw\tft/tft.c ****     uint8_t hi = color >> 8, lo = color;
 572:Source\bsw\tft/tft.c **** 
 573:Source\bsw\tft/tft.c ****     TFT_DC_HIGH;
 574:Source\bsw\tft/tft.c **** 
 575:Source\bsw\tft/tft.c ****     while (w--) {
 576:Source\bsw\tft/tft.c ****         TFT_write_stream(hi);
 577:Source\bsw\tft/tft.c ****         TFT_write_stream(lo);
 578:Source\bsw\tft/tft.c ****     }
 579:Source\bsw\tft/tft.c **** }
