 355:Source\bsw\tft/tft.c **** void TFT_setFont(const GFXfont *f) {
 356:Source\bsw\tft/tft.c ****     if(f) {            // Font struct pointer passed in?
 357:Source\bsw\tft/tft.c ****         if(!gfxFont) { // And no current font struct?
 358:Source\bsw\tft/tft.c ****             // Switching from classic to new font behavior.
 359:Source\bsw\tft/tft.c ****             // Move cursor pos down 6 pixels so it's on baseline.
 360:Source\bsw\tft/tft.c ****             cursor_y += 6;
 361:Source\bsw\tft/tft.c ****         }
 362:Source\bsw\tft/tft.c ****     } else if(gfxFont) { // NULL passed.  Current font struct defined?
 363:Source\bsw\tft/tft.c ****         // Switching from new to classic font behavior.
 364:Source\bsw\tft/tft.c ****         // Move cursor pos up 6 pixels so it's at top-left of char.
 365:Source\bsw\tft/tft.c ****         cursor_y -= 6;
 366:Source\bsw\tft/tft.c ****     }
 367:Source\bsw\tft/tft.c ****     gfxFont = (GFXfont *)f;
 368:Source\bsw\tft/tft.c **** }
