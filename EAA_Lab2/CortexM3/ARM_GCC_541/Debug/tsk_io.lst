 154:.\Source\rte/sc_event.h ****  * Depending on the configured conversion or scaling function the raw_value will be calculated.
 155:.\Source\rte/sc_event.h ****  * Signal status will change from RTE_SIGNALSTATUS_STARTUP to RTE_SIGNALSTATUS_INITIALIZED.
 156:.\Source\rte/sc_event.h ****  *
 157:.\Source\rte/sc_event.h ****  * @param  SC_EVENT_t * const signal: Pointer to the signal object which will be initialised
 158:.\Source\rte/sc_event.h ****  * @param const sc_event_data_t * const value: Pointer to initial value of the application data
 159:.\Source\rte/sc_event.h ****  * @return RC_t: standard return code, currently only RC_SUCCESS
 160:.\Source\rte/sc_event.h ****  *
 161:.\Source\rte/sc_event.h ****  **/
 162:.\Source\rte/sc_event.h **** inline RC_t RTE_SC_EVENT_init( SC_EVENT_t * const signal, const SC_EVENT_data_t * const value )
 163:.\Source\rte/sc_event.h **** {                                                                                                  
 164:.\Source\rte/sc_event.h **** 
 165:.\Source\rte/sc_event.h ****    RC_t ret = RC_SUCCESS;
 166:.\Source\rte/sc_event.h **** 
 167:.\Source\rte/sc_event.h ****    //Set value and raw value
 168:.\Source\rte/sc_event.h ****    signal->value  = *value;
 169:.\Source\rte/sc_event.h ****    signal->age    = 0;
 170:.\Source\rte/sc_event.h ****    signal->status = RTE_SIGNALSTATUS_INITIALIZED;
 171:.\Source\rte/sc_event.h **** 
 172:.\Source\rte/sc_event.h ****    return ret;
 173:.\Source\rte/sc_event.h **** }
